---
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";
import { type Locale, defaultLocale } from "@/i18n/translations";

type Props = MarkdownLayoutProps<{ title: string; lang?: Locale }>;

const { frontmatter } = Astro.props;
const lang: Locale = (frontmatter.lang as Locale) ?? defaultLocale;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`} {lang}>
  <Header {lang} />
  <Breadcrumb {lang} />
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl tracking-wider sm:text-3xl">{frontmatter.title}</h1>
      <slot />
    </section>
  </main>
  <Footer {lang} />
</Layout>
