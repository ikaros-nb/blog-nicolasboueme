---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";
import { t } from "@/i18n/translations";

const lang = "fr" as const;

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const tags = getUniqueTags(posts, "fr");

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag, "fr");

    return paginate(tagPosts, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props;
---

<Layout title={`${t(lang, "tags.tagPrefix")} ${tagName} | ${SITE.title}`} {lang}>
  <Header {lang} />
  <Main
    pageTitle={[`${t(lang, "tags.tagPrefix")}`, `${tagName}`]}
    titleTransition={tag}
    pageDesc={t(lang, "tags.tagDesc").replace("{tagName}", tagName)}
    {lang}
  >
    <h1 slot="title" transition:name={tag}>{`Tag:${tag}`}</h1>
    <ul>
      {page.data.map(data => <Card {lang} {...data} />)}
    </ul>
  </Main>

  <Pagination {page} {lang} />

  <Footer noMarginTop={page.lastPage > 1} {lang} />
</Layout>
