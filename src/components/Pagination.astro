---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import LinkButton from "./LinkButton.astro";
import { type Locale, defaultLocale, t } from "@/i18n/translations";

type Props = {
  page: Page<CollectionEntry<"blog">>;
  lang?: Locale;
};

const { page, lang = defaultLocale } = Astro.props;
---

{
  page.lastPage > 1 && (
    <nav
      class="mt-auto mb-8 flex justify-center"
      role="navigation"
      aria-label="Pagination Navigation"
    >
      <LinkButton
        disabled={!page.url.prev}
        href={page.url.prev as string}
        class:list={["me-4 select-none", { "opacity-50": !page.url.prev }]}
        aria-label={t(lang, "pagination.gotoPrev")}
      >
        <IconArrowLeft class="inline-block rtl:rotate-180" />
        {t(lang, "pagination.prev")}
      </LinkButton>
      {page.currentPage} / {page.lastPage}
      <LinkButton
        disabled={!page.url.next}
        href={page.url.next as string}
        class:list={["ms-4 select-none", { "opacity-50": !page.url.next }]}
        aria-label={t(lang, "pagination.gotoNext")}
      >
        {t(lang, "pagination.next")}
        <IconArrowRight class="inline-block rtl:rotate-180" />
      </LinkButton>
    </nav>
  )
}
